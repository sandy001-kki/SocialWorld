# Your Render.com backend URL (no trailing slash)
VITE_API_URL=http://localhost:3001

# From Meta Developer Portal > Your App > Basic Settings
VITE_INSTAGRAM_APP_ID=your_instagram_app_id

# Must match INSTAGRAM_REDIRECT_URI in the server .env exactly
VITE_INSTAGRAM_REDIRECT_URI=http://localhost:3001/api/auth/callback
