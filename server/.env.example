# Instagram Basic Display API credentials
# Get these from https://developers.facebook.com/apps/
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret

# Must match exactly what you set in the Meta Developer Portal
# e.g. https://your-backend.onrender.com/api/auth/callback
INSTAGRAM_REDIRECT_URI=http://localhost:3001/api/auth/callback

# Supabase credentials — get from your Supabase project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# Random secret string for signing JWTs — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# Frontend URL for CORS (set to your Vercel URL in production)
CLIENT_URL=http://localhost:5173

PORT=3001
